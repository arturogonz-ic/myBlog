---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../../shared/components/BaseHead.astro';
import Footer from '../../shared/components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../../shared/components/Header.astro';

const baseUrl = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');

type Props = CollectionEntry<'blog'>['data'] & {
	recommendedPosts?: CollectionEntry<'blog'>[];
};

const { title, description, date, author, image, tags = [], recommendedPosts = [] } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--text-primary);
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: var(--text-secondary);
				font-size: 0.95em;
			}
			.author {
				font-weight: 500;
			}
			.tags {
				display: flex;
				gap: 0.5em;
				margin-top: 0.5em;
				justify-content: center;
				flex-wrap: wrap;
			}
			.tag {
				display: inline-block;
				padding: 0.25em 0.75em;
				background-color: var(--bg-secondary);
				border-radius: 20px;
				font-size: 0.9em;
				color: var(--accent);
				text-decoration: none;
				transition: background-color 0.2s;
			}
			.tag:hover {
				background-color: var(--border-color);
			}
			.recommended-posts {
				margin-top: 3em;
				padding-top: 2em;
				border-top: 1px solid var(--border-color);
			}
			.recommended-posts h2 {
				margin-bottom: 1.5em;
				color: var(--text-primary);
			}
			.posts-list {
				display: grid;
				gap: 1.5em;
			}
			.post-item {
				padding: 1em;
				background-color: var(--bg-secondary);
				border-radius: 8px;
				transition: transform 0.2s, box-shadow 0.2s;
			}
			.post-item:hover {
				transform: translateY(-2px);
				box-shadow: var(--shadow);
			}
			.post-item h3 {
				margin: 0 0 0.5em 0;
				font-size: 1.2em;
			}
			.post-item a {
				color: var(--accent);
				text-decoration: none;
			}
			.post-item a:hover {
				text-decoration: underline;
			}
			.post-meta {
				font-size: 0.9em;
				color: var(--text-secondary);
				margin-bottom: 0.5em;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{image && (
					<div class="hero-image">
						<img src={`${baseUrl}${image}`} alt={title} />
					</div>
				)}
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={date} />
							{author && <div class="author">By {author}</div>}
						</div>
						<h1>{title}</h1>
						{tags && tags.length > 0 && (
							<div class="tags">
								{tags.map((tag) => (
									<a href={`${baseUrl}/blog/?tag=${tag}`} class="tag">
										#{tag}
									</a>
								))}
							</div>
						)}
						<hr />
					</div>
					<slot />
					{recommendedPosts && recommendedPosts.length > 0 && (
						<div class="recommended-posts">
							<h2>Recommended Posts</h2>
							<div class="posts-list">
								{recommendedPosts.map((post) => (
									<div class="post-item">
										<h3>
											<a href={`${baseUrl}/blog/${post.id}`}>{post.data.title}</a>
										</h3>
										<p class="post-meta">
											By {post.data.author} • <FormattedDate date={post.data.date} />
										</p>
										<p>{post.data.description}</p>
									</div>
								))}
							</div>
						</div>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
